extends external

block mainContent
	section.bp-hero
		.bp-hero-copy
			.bp-eyebrow
				span.bp-dot
				| You're invited
			h1.bp-hero-title Join <em>#{room.title}</em>
			p.bp-hero-lead Hop in to estimate with your team. We just need a couple details.

		.bp-action-card
			.bp-tab-panel.is-active(data-panel="join")
				form#join(action="/join")
					input#room-id(name='room-id', type='hidden', value='#{room.roomId}')
					label.bp-field
						span.bp-field-label Your name
						input#name(name='name', type='text', placeholder='Avery', data-required='true', autocomplete='name')
					label.bp-field
						span.bp-field-label Gravatar email
						input#email(name='email', type='email', placeholder='optional', autocomplete='email')
					input#join-room.bp-btn.bp-btn-primary(type='submit', value='Join Room →')
			p.bp-invite-fallback or, head to <a href="/">bitpoints.io</a>
