extends external

block mainContent
	section.bp-hero
		.bp-hero-copy
			.bp-eyebrow
				span.bp-dot
				| Live · #{voterString} estimating in #{roomString}
			h1.bp-hero-title Estimate stories together — <em>instantly.</em>
			p.bp-hero-lead Planning poker for distributed scrum teams. No accounts. No installs. Share a link, pick a card, ship faster.
			.bp-hero-specs
				span No accounts
				span No installs
				span Open source
				span Sub-second sync

		.bp-action-card
			.bp-action-card-head
				span Start / Join
				span 02 modes
			.bp-tabs(role="tablist")
				button.bp-tab.is-active(type="button", data-target="create", role="tab", aria-selected="true") Start a Room
				button.bp-tab(type="button", data-target="join", role="tab", aria-selected="false") Join a Room

			.bp-tab-panel.is-active(data-panel="create")
				form#create(action="/create")
					label.bp-field
						span.bp-field-label Room title
						input#title(name='title', type='text', placeholder='Sprint 42 Planning', data-required='true', autocomplete='off')
					.roomOptions
						label.bp-checkbox(for='notifications')
							input#notifications(name='notifications', type='checkbox', value='yes')
							span.bp-checkbox-box
							span.bp-checkbox-label Desktop notifications when votes land
					input#create-submit.bp-btn.bp-btn-primary(type='submit', value='Create Room →')

			.bp-tab-panel(data-panel="join")
				form#join(action="/join")
					label.bp-field
						span.bp-field-label Room ID
						input#room-id(name='room-id', type='text', placeholder='e.g. 42591', data-required='true', autocomplete='off')
					.bp-field-row
						label.bp-field
							span.bp-field-label Your name
							input#name(name='name', type='text', placeholder='Avery', data-required='true', autocomplete='name')
						label.bp-field
							span.bp-field-label Gravatar email
							input#email(name='email', type='email', placeholder='optional', autocomplete='email')
					input#join-room.bp-btn.bp-btn-primary(type='submit', value='Join Room →')

block supplementalContent
	.bp-section-head
		.bp-section-kicker §01 — Features
		h2 Built for <em>fast</em> consensus.
	section.bp-features
		.bp-feature
			.bp-feature-icon: i.fa.fa-bolt
			h3 Real-time consensus
			p Live averages, min/max highlights, large-spread warnings — the moment the last vote lands.
		.bp-feature
			.bp-feature-icon: i.fa.fa-th-large
			h3 Decks for every team
			p Standard, Fibonacci, T-Shirt, Letters. Switch mid-session and everyone updates instantly.
		.bp-feature
			.bp-feature-icon: i.fa.fa-paint-brush
			h3 Cards with character
			p 25+ patterns, custom color picker, persistent preferences — yes, even the goat is still here.
		.bp-feature
			.bp-feature-icon: i.fa.fa-eye-slash
			h3 Observer mode
			p Stakeholders watch without skewing the average. PMs, designers — welcome aboard.

	section.bp-how
		.bp-section-head
			.bp-section-kicker §02 — How it works
			h2 Three steps. About <em>thirty</em> seconds.
		ol.bp-steps
			li
				span.bp-step-num 01
				h4 Spin up a room
				p Pick a title. We mint a short link you can paste anywhere.
			li
				span.bp-step-num 02
				h4 Teammates join
				p Names, optional Gravatar, and they're in. Mobile-friendly.
			li
				span.bp-step-num 03
				h4 Reveal & ship
				p Open a round, everyone votes, host closes — the average drops with a flourish.
