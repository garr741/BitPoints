extends layout

block content
	header.bp-room-header
		a.bp-logo(href="/")
			span.bp-logo-mark BP
			span BitPoints
		.bp-room-meta
			.bp-room-title
				h1 #{room.title}
				span.bp-room-id ##{room.roomId}
		button.bp-share-copy(type="button", data-invite=inviteId, title="Copy invite link")
			span.bp-share-copy-label INVITE
			span.bp-share-copy-url(data-host=appHost) #{appHost}/#{inviteId}
			i.fa.fa-clipboard

	main#room.bp-room
		section.bp-round-bar
			.bp-round-bar-controls
				button#toggleRound.bp-btn-round Begin Estimating
				.bp-deck-switch
					button.bp-deck-trigger(type="button", aria-haspopup="true", aria-expanded="false")
						span.bp-deck-mini-label Deck
						span.bp-deck-value Fibonacci
						i.fa.fa-angle-down
					.bp-deck-menu(role="menu")
						label.bp-deck-option
							input(type="radio", value="standard", name="deckType")
							span Standard
						label.bp-deck-option
							input(type="radio", value="fibonacci", name="deckType", checked="checked")
							span Fibonacci
						label.bp-deck-option
							input(type="radio", value="letters", name="deckType")
							span Letters
						label.bp-deck-option
							input(type="radio", value="tshirt", name="deckType")
							span T-Shirt
				label.bp-auto-reveal(for="autoReveal")
					input(type="checkbox", name="autoReveal", id="autoReveal", checked="checked")
					span.bp-switch-track
						span.bp-switch-thumb
					span.bp-auto-reveal-label Auto-reveal
			#ticket.bp-ticket
			.bp-round-results
				.bp-progress
					span.bp-progress-count
						span.bp-progress-now 0
						span.bp-progress-sep /
						span.bp-progress-total 0
					.bp-progress-bar
						.bp-progress-fill
					span.bp-progress-label voted

		section.bp-results-row
			#distribution.bp-distribution
			.bp-results-stats
				#recommendation.bp-recommendation
					span.bp-rec-label Should be
					span.bp-rec-arrow →
					span.bp-rec-value
					span.bp-rec-subtext

		ul#users.bp-voters

		section.bp-share-cta
			.bp-share-cta-eyebrow Invite link
			h2 Send this link to your team.
			p.bp-share-cta-lead Voters join in seconds. No accounts, no installs. Sub-second sync.
			.bp-share-cta-row
				input.bp-share-cta-url(type="text", readonly, value=appHost+"/"+inviteId, data-invite=inviteId)
				button.bp-share-cta-copy(type="button") Copy link

	script.
		BP.room = !{JSON.stringify(room)};
		BP.inviteId = '!{inviteId}';
		BP.appHost = '!{appHost}';
	script(src="/socket.io/socket.io.js")
	script(src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js")
	script(src='/javascripts/host.js')
